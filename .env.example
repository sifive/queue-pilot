PORT=8080
SLURM_ADAPTER=cli            # cli | restd | mock
SLURM_CLUSTERS=compute1,testbed,primo
SLURM_DEFAULT_CLUSTER=compute1
SLURM_SSH_HOST=              # e.g. pe01.internal.sifive.com ; empty = run binaries locally
SLURM_SSH_USER=
SLURMRESTD_URL=             # e.g. http://hpcmaster:6820 (restd adapter)
SLURMRESTD_API_VERSION=v0.0.42
SLURM_POLL_SECONDS=30        # min 10
HISTORY_RETENTION_DAYS=30
ETA_MODEL=heuristic          # heuristic | simulation
DB_PATH=./queuepilot.sqlite
AI_NARRATIVE=off             # off | on
AI_BASE_URL=
AI_MODEL=
ENABLE_ACTIONS=false         # MUST stay false; gates any mutating Slurm calls (out of scope v1)
